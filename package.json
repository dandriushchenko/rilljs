{
  "name": "@dandriushchenko/rilljs",
  "version": "2.0.2",
  "type": "module",
  "main": "dist/rilljs.umd.js",
  "module": "dist/rilljs.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rilljs.es.js",
      "require": "./dist/rilljs.umd.js"
    },
    "./dist/styles/theme.css": {
      "style": "./dist/styles/theme.css",
      "default": "./dist/styles/theme.css"
    },
    "./Editor/themes/theme.css": {
      "style": "./dist/styles/theme.css",
      "default": "./dist/styles/theme.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "vite build -m demo",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare": "husky",
    "format": "prettier --write .",
    "circular": "dpdm -T --no-warning --no-tree ./src",
    "test": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "dpdm": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  }
}
